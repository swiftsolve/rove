{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rove",
  "mainBinaryName": "Rove",
  "version": "0.0.3",
  "identifier": "com.rove.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rove",
        "width": 500,
        "height": 660,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "deb",
      "dmg",
      "nsis",
      "msi"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "iproute2",
          "iputils-ping"
        ],
        "files": {
          "/etc/apparmor.d/rove": "linux/rove.apparmor"
        },
        "postInstallScript": "linux/postinst.sh",
        "preRemoveScript": "linux/prerm.sh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "ZFc1MGNuVnpkR1ZrSUdOdmJXMWxiblE2SUcxcGJtbHphV2R1SUhCMVlteHBZeUJyWlhrNklFRTBRVGczT1VVMU5qVTRSRUZHUmtNS1VsZFVPSEkwTVd3MVdHMXZjRVUwY1RsWmRISmpSRGxCWkVFM0wzRTBURkJKY0VKME1VaDRjVWhwVmxacFYwdGpaSHBhZVU1aFdXa0s=",
      "endpoints": [
        "https://github.com/swiftsolve/rove/releases/latest/download/latest.json"
      ]
    }
  }
}
