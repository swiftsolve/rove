{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beacon",
  "version": "1.0.0",
  "identifier": "com.beacon.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Beacon",
        "width": 500,
        "height": 640,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "backgroundColor": "#0a0b0e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "dmg", "nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1"]
      }
    }
  }
}
