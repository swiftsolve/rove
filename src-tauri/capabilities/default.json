{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Main window + tray popover: events for progress/throughput, frameless window controls",
  "windows": ["main", "popover"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "updater:default",
    "process:default"
  ]
}
